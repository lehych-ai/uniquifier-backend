# CloserAI GPU backend — pod environment

# Require this bearer token on every /api request (recommended on public IPs).
# Leave empty for open access behind a private proxy.
API_TOKEN=

# Where weights live and where work files go.
MODELS_DIR=/root/models
UPLOAD_DIR=/tmp/uploads
OUTPUT_DIR=/tmp/outputs

# Inpainting model for random_bg / random_clothes generation.
SD_INPAINT_MODEL=stabilityai/stable-diffusion-2-inpainting

# Port uvicorn binds (the Vast proxy maps this).
PORT=8000
